/* pages/gallery/gallery.wxss */
.page {
  min-height: 100vh;
  background: var(--cream);
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(180deg, #C41E3A, #8B0000);
  padding: 50rpx 30rpx 40rpx;
  text-align: center;
  border-radius: 0 0 30rpx 30rpx;
}

.title {
  font-size: 40rpx;
  color: #FFD700;
  font-weight: bold;
  display: block;
}

.count {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 36rpx;
  color: var(--text-dark);
  font-weight: bold;
}

.empty-hint {
  font-size: 28rpx;
  color: var(--text-light);
  margin: 16rpx 0 40rpx;
}

/* 作品网格 */
.gallery-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  gap: 16rpx;
}

.gallery-item {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.gallery-img {
  width: 100%;
  height: 300rpx;
  display: block;
}

.item-info {
  padding: 16rpx 20rpx;
}

.item-style {
  font-size: 26rpx;
  color: var(--red);
  font-weight: bold;
  display: block;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 26rpx;
}
