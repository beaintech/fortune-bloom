<!-- pages/profile/profile.wxml - 个人中心 -->
<view class="page">
  
  <!-- 用户信息 -->
  <view class="user-card">
    <image class="avatar" src="{{avatarUrl || 'https://mmbiz.qpic.cn/mmbiz/icTdbqWNOwNRna42FI242Lcia07jQodd2FJGIYQfG0LAJGFxM4FbnQP6yfMxBgJ0F3YRqJCJ1aPAK2dQagdusBZg/0'}}" bindtap="onAvatarTap" />
    <view class="user-info">
      <text class="nickname">{{nickName || '富贵用户'}}</text>
      <view class="vip-badge" wx:if="{{isVip}}">
        <text>🌟 VIP会员</text>
      </view>
      <view class="free-badge" wx:else>
        <text>免费用户</text>
      </view>
    </view>
  </view>

  <!-- 使用统计 -->
  <view class="stats-card card">
    <view class="stat-item">
      <text class="stat-num">{{totalGenerated}}</text>
      <text class="stat-label">已生成</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{todayGenerated}}</text>
      <text class="stat-label">今日使用</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{isVip ? 'VIP' : remainingStyles}}</text>
      <text class="stat-label">{{isVip ? '会员专属' : '免费风格剩余'}}</text>
    </view>
  </view>

  <!-- VIP 使用详情 -->
  <view class="vip-usage" wx:if="{{isVip && vipUsageText}}">
    <text class="vip-usage-text">{{vipUsageText}}</text>
  </view>

  <!-- 会员套餐 -->
  <view class="section-title">💎 开通会员 · 畅享生成</view>
  <view class="plan-note">* 为防止滥用，会员设有月度生成上限</view>
  
  <view class="plans">
    <!-- 日卡 -->
    <view class="plan-card {{!isVip ? 'recommend' : ''}}" bindtap="buyPlan" data-plan="day">
      <view class="plan-header">
        <text class="plan-name">日卡</text>
        <text class="plan-badge" wx:if="{{!isVip}}">推荐</text>
      </view>
      <view class="plan-body">
        <view class="plan-price">
          <text class="price-symbol">¥</text>
          <text class="price-num">2.9</text>
        </view>
        <view class="plan-info">
          <text class="plan-desc">24小时内最多 10 张</text>
          <text class="plan-save">适合尝鲜体验</text>
        </view>
      </view>
    </view>

    <!-- 月卡 -->
    <view class="plan-card hot" bindtap="buyPlan" data-plan="month">
      <view class="plan-header">
        <text class="plan-name">月卡</text>
        <text class="plan-badge hot-badge">🔥 最划算</text>
      </view>
      <view class="plan-body">
        <view class="plan-price">
          <text class="price-symbol">¥</text>
          <text class="price-num">12.9</text>
        </view>
        <view class="plan-info">
          <text class="plan-desc">30天内最多 50 张</text>
          <text class="plan-save">平均每天 ¥0.43</text>
        </view>
      </view>
    </view>

    <!-- 年卡 -->
    <view class="plan-card" bindtap="buyPlan" data-plan="year">
      <view class="plan-header">
        <text class="plan-name">年卡</text>
      </view>
      <view class="plan-body">
        <view class="plan-price">
          <text class="price-symbol">¥</text>
          <text class="price-num">79</text>
        </view>
        <view class="plan-info">
          <text class="plan-desc">365天内最多 300 张</text>
          <text class="plan-save">平均每天 ¥0.22，省最多</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能介绍 -->
  <view class="features card-gold">
    <text class="feature-title">VIP专属权益</text>
    <view class="feature-item" wx:for="{{vipFeatures}}" wx:key="index">
      <text class="feature-icon">{{item.icon}}</text>
      <text class="feature-text">{{item.text}}</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text>🌸 富贵花开 v1.0</text>
    <text class="footer-link" bindtap="showAgreement">用户协议</text>
    <text class="footer-link" bindtap="showPrivacy">隐私政策</text>
  </view>
</view>
