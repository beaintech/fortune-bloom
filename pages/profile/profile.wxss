/* pages/profile/profile.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--cream) 0%, #FFF0F0 100%);
  padding-bottom: 60rpx;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #C41E3A, #8B0000);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 0 0 30rpx 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #FFD700;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
  display: block;
}

.vip-badge {
  background: linear-gradient(135deg, #FFD700, #DAA520);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-top: 8rpx;
}

.vip-badge text {
  font-size: 24rpx;
  color: #8B0000;
  font-weight: bold;
}

.free-badge {
  background: rgba(255,255,255,0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-top: 8rpx;
}

.free-badge text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 统计卡片 */
.stats-card {
  margin: -20rpx 30rpx 30rpx;
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--red);
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: #EEEEEE;
}

/* 套餐标题 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-dark);
  text-align: center;
  padding: 30rpx 20rpx 20rpx;
}

/* 套餐卡片 */
.plans {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 3rpx solid #EEEEEE;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.plan-card.recommend {
  border-color: var(--red);
  background: #FFF5F5;
  position: relative;
}

.plan-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.plan-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
}

.plan-badge {
  background: var(--red);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.plan-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 28rpx;
  color: var(--red);
  font-weight: bold;
}

.price-num {
  font-size: 52rpx;
  color: var(--red);
  font-weight: bold;
  line-height: 1;
}

.plan-desc {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-top: 6rpx;
}

.plan-save {
  font-size: 22rpx;
  color: var(--gold);
  display: block;
  margin-top: 4rpx;
}

/* 功能介绍 */
.features {
  margin: 30rpx;
}

.feature-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-dark);
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 36rpx;
}

.feature-text {
  font-size: 28rpx;
  color: var(--text-mid);
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.footer-link {
  margin-left: 20rpx;
  color: var(--red);
}
