/* pages/result/result.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFF0F0 100%);
  padding-bottom: 40rpx;
}

.result-header {
  background: linear-gradient(180deg, #C41E3A, #8B0000);
  padding: 50rpx 30rpx 60rpx;
  text-align: center;
  border-radius: 0 0 40rpx 40rpx;
}

.result-title {
  font-size: 48rpx;
  color: #FFD700;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.result-sub {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 结果卡片 */
.result-card {
  margin: -40rpx 30rpx 30rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 4rpx solid var(--gold);
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(139,0,0,0.15);
  position: relative;
}

.result-img {
  width: 100%;
  display: block;
}

.result-watermark {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: var(--gold);
  font-weight: bold;
  letter-spacing: 4rpx;
}

/* 操作按钮 */
.actions {
  padding: 20rpx 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #C41E3A, #8B0000);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(196,30,58,0.3);
}

.action-btn.gold {
  background: linear-gradient(135deg, #D4A017, #B8860B);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(212,160,23,0.3);
}

.action-btn.outline {
  background: #FFFFFF;
  color: var(--red);
  border: 2rpx solid var(--red);
}

/* VIP横幅 */
.vip-banner {
  margin: 20rpx 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF8DC, #FFE4B5);
  border-radius: 16rpx;
  border: 2rpx solid var(--gold);
  text-align: center;
}

.vip-text {
  font-size: 30rpx;
  color: #8B6914;
  font-weight: bold;
}

/* 分享引导 */
.share-guide {
  text-align: center;
  padding: 40rpx;
}

.guide-text {
  font-size: 28rpx;
  color: var(--red);
  font-weight: bold;
}
