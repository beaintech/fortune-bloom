/* app.wxss - 富贵花开全局样式 */

/* 颜色变量 */
page {
  --red: #C41E3A;
  --red-dark: #8B0000;
  --gold: #D4A017;
  --gold-light: #FFD700;
  --cream: #FFF8F0;
  --warm-bg: #FFF5EE;
  --text-dark: #3D1C1C;
  --text-mid: #6B4B3E;
  --text-light: #9E7B6B;
  
  background-color: var(--cream);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 32rpx;
  color: var(--text-dark);
  line-height: 1.6;
}

/* 大字体 - 适配中老年用户 */
.text-xl {
  font-size: 44rpx;
  font-weight: bold;
}
.text-lg {
  font-size: 36rpx;
  font-weight: bold;
}
.text-md {
  font-size: 30rpx;
}
.text-sm {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 按钮 - 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--red), var(--red-dark));
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 60rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(196, 30, 58, 0.3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 金色描边按钮 */
.btn-gold {
  background: linear-gradient(135deg, var(--gold), #B8860B);
  color: #FFFFFF;
  border: 2rpx solid var(--gold-light);
  border-radius: 48rpx;
  padding: 24rpx 60rpx;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(212, 160, 23, 0.3);
}

/* 卡片容器 */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 金色边框卡片 */
.card-gold {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  border: 3rpx solid var(--gold);
  box-shadow: 0 4rpx 20rpx rgba(212, 160, 23, 0.15);
}

/* 页面标题 */
.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-dark);
  text-align: center;
  padding: 40rpx 20rpx 20rpx;
}

/* 牡丹花装饰分割线 */
.divider-flower {
  text-align: center;
  font-size: 48rpx;
  color: var(--red);
  margin: 20rpx 0;
  letter-spacing: 20rpx;
}

/* flex布局工具 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-column {
  display: flex;
  flex-direction: column;
}
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 底部安全区 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
